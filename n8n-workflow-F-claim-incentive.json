      "id": "respond-preflight",
      "name": "Respond - Preflight OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [480, 160]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst clientId = String(body.clientId || '').trim();\nconst email = String(body.email || '').toLowerCase().trim();\n\nif (!clientId || !email || !email.includes('@')) {\n  throw new Error('Invalid clientId or email');\n}\n\nconst couponSearchUrl = 'https://api.airtable.com/v0/appwlnvY7rceVb06Q/tbljuu3kuNFezEanG?filterByFormula=' + encodeURIComponent(\"AND({clientId}='\" + clientId + \"',{email}='\" + email + \"')\") + '&maxRecords=1';\nconst clientSearchUrl = 'https://api.airtable.com/v0/appwlnvY7rceVb06Q/tblxTlomzuupQcgyY?filterByFormula=' + encodeURIComponent(\"{clientId}='\" + clientId + \"'\") + '&maxRecords=1';\n\nreturn [{ json: { clientId, email, couponSearchUrl, clientSearchUrl } }];"
      },
      "id": "code-normalize",
      "name": "Code - Normalize",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 400]
    },
    {
      "parameters": {
        "url": "={{ $json.couponSearchUrl }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "id": "http-search-coupons",
      "name": "HTTP - Search Coupons",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [720, 400],
      "credentials": {
        "httpHeaderAuth": { "id": "CDKXmqf7Ugjt0kAD", "name": "Airtable Admin PAT" }
      }
    },
    {
      "parameters": {
        "jsCode": "const records = $input.first().json.records || [];\nconst prev = $('Code - Normalize').item.json;\n\nif (records.length > 0) {\n  return [{ json: { ...prev, alreadyClaimed: true, couponCode: records[0].fields.couponCode || '' } }];\n}\n\nconst prefix = prev.clientId.replace(/[^a-zA-Z]/g, '').slice(0, 3).toUpperCase().padEnd(3, 'X');\nconst random = Math.random().toString(36).slice(2, 8).toUpperCase();\nconst couponCode = prefix + '-' + random;\n\nreturn [{ json: { ...prev, alreadyClaimed: false, couponCode } }];"
      },
      "id": "code-check-claimed",
      "name": "Code - Check Claimed",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 400]
    },
