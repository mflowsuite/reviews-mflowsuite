      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1440, 540],
      "credentials": {
        "httpHeaderAuth": { "id": "CDKXmqf7Ugjt0kAD", "name": "Airtable Admin PAT" }
      }
    },
    {
      "parameters": {
        "jsCode": "const clientRecord = ($input.first().json.records || [])[0];\nconst fields = clientRecord ? clientRecord.fields : {};\nconst prev = $('Code - Check Claimed').item.json;\n\nconst businessName = fields.businessName || prev.clientId;\nconst incentiveText = fields.incentiveText || 'Premio especial';\nconst notificationEmail = String(fields.notificationEmail || '').trim();\nconst { clientId, email, couponCode } = prev;\nconst claimedAt = new Date().toISOString();\n\nconst clientEmailSubject = '🎁 Tu regalo de ' + businessName;\nconst clientEmailBody = 'Hola!\\n\\nGracias por dejar tu reseña en ' + businessName + '.\\n\\n' +\n  'Tu premio: ' + incentiveText + '\\n\\n' +\n  'Código: ' + couponCode + '\\n\\n' +\n  'Mostrá este email en el local para canjearlo.\\n\\n¡Hasta pronto! 🙌';\n\nconst businessEmailSubject = '🎁 Nuevo cupón reclamado — ' + businessName;\nconst businessEmailBody = 'Un cliente reclamó su incentivo:\\n\\n' +\n  'Email: ' + email + '\\n' +\n  'Código: ' + couponCode + '\\n' +\n  'Fecha: ' + claimedAt + '\\n\\n' +\n  'Premio: ' + incentiveText;\n\nreturn [{ json: { clientId, email, couponCode, businessName, incentiveText, notificationEmail, claimedAt, clientEmailSubject, clientEmailBody, businessEmailSubject, businessEmailBody, hasNotificationEmail: notificationEmail.length > 0 } }];"
      },
