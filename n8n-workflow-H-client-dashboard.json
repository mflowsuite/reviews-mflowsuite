      "parameters": {
        "jsCode": "const records = $input.first().json.records || [];\nconst prev = $('Code - Validate Auth').item.json;\n\nif (records.length === 0) {\n  return [{ json: { ...prev, notFound: true, recordId: null, client: null } }];\n}\n\nconst record = records[0];\nconst clientFields = record.fields;\n\nconst storedPassword = String(clientFields.clientPassword || '').trim();\nconst passwordOk = storedPassword === prev.password;\n\nif (!passwordOk) {\n  return [{ json: { ...prev, notFound: false, authFailed: true, recordId: null, client: null } }];\n}\n\nconst { clientPassword, ...safeFields } = clientFields;\n\nreturn [{ json: { ...prev, notFound: false, authFailed: false, recordId: record.id, client: safeFields } }];"
