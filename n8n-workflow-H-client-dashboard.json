    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst email = String(body.email || '').toLowerCase().trim();\nconst password = String(body.password || '').trim();\nconst action = String(body.action || '').trim();\nconst fields = body.fields || null;\n\nif (!email || !action) {\n  throw new Error('email and action are required');\n}\nif (!['get', 'save', 'forgot-password'].includes(action)) {\n  throw new Error('invalid action');\n}\n// forgot-password does not require a password\nif (action !== 'forgot-password' && !password) {\n  throw new Error('password is required');\n}\n\nconst searchUrl = 'https://api.airtable.com/v0/appwlnvY7rceVb06Q/tblxTlomzuupQcgyY?filterByFormula=' + encodeURIComponent(\"{notificationEmail}='\" + email + \"'\") + '&maxRecords=1';\n\nreturn [{ json: { email, password, action, fields, searchUrl } }];"
