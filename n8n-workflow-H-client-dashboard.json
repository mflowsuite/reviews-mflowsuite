      "parameters": {
        "jsCode": "const records = $input.first().json.records || [];\nconst prev = $('Code - Validate Auth').item.json;\n\nif (records.length === 0) {\n  // Don't reveal if email exists\n  return [{ json: { ...prev, shouldSendEmail: false } }];\n}\n\nconst fields = records[0].fields;\nconst clientPassword = String(fields.clientPassword || '').trim();\nconst businessName = fields.businessName || 'mflowsuite';\n\nreturn [{ json: { ...prev, shouldSendEmail: true, clientPassword, businessName } }];"
