    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst email = String(body.email || '').toLowerCase().trim();\nconst password = String(body.password || '').trim();\nconst action = String(body.action || '').trim();\nconst fields = body.fields || null;\n\nif (!email || !password || !action) {\n  throw new Error('email, password and action are required');\n}\nif (action !== 'get' && action !== 'save') {\n  throw new Error('action must be get or save');\n}\n\nconst searchUrl = 'https://api.airtable.com/v0/appwlnvY7rceVb06Q/tblxTlomzuupQcgyY?filterByFormula=' + encodeURIComponent(\"{notificationEmail}='\" + email + \"'\") + '&maxRecords=1';\n\nreturn [{ json: { email, password, action, fields, searchUrl } }];"
      },
      "id": "code-validate-auth",
      "name": "Code - Validate Auth",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 400]
