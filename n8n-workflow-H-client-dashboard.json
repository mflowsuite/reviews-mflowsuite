    {
      "parameters": {
        "jsCode": "const prev = $input.first().json;\nconst rawFields = prev.fields || {};\n\n// Fields that cannot be changed by the client\nconst immutable = ['clientId', 'active', 'clientPassword'];\n\nconst filtered = {};\nfor (const [k, v] of Object.entries(rawFields)) {\n  if (immutable.includes(k)) continue;\n  // Convert empty strings to null to clear fields in Airtable\n  filtered[k] = (v === '') ? null : v;\n}\n\nconst updateUrl = 'https://api.airtable.com/v0/appwlnvY7rceVb06Q/tblxTlomzuupQcgyY/' + prev.recordId;\n\nreturn [{ json: { ...prev, filteredFields: filtered, updateUrl } }];"
      },
